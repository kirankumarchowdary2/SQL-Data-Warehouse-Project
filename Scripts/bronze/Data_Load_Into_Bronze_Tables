/*
===================================================================
Scripts Purpose:
   This Scripts is used to load data into the broze schema from external csv files.
   It Peroforms the following actions:
    -Truncates the bronze tables before loading data.
    -Uses the COPY INTO command to load data from external csv files to bronze tables.
=======================================================================
*\



%md
### Start Time of the Loading
CREATE OR REPLACE TEMP VIEW notebook_start_time AS
SELECT current_timestamp() AS start_time;

use catalog sql_datawarehouse;
%md
### Bulk inserting into bronze.crm_cust_info 
-- Loading Bronze Layer
truncate table sql_datawarehouse.bronze.crm_cust_info;
copy into sql_datawarehouse.bronze.crm_cust_info from '/Volumes/de_dev/default/datasets/datasets/source_crm/cust_info.csv'
fileformat=csv
format_options(
  'header' = 'true',
  'inferSchema' = 'true'
);
%md
### Testing out the data insertion check
select * from sql_datawarehouse.bronze.crm_cust_info;
