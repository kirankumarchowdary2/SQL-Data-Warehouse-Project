%md
### Print End time of the bronze layer loading
SELECT current_timestamp() AS execution_start_time;

SELECT
  notebook_start_time.start_time,
  current_timestamp() AS end_time,
  CAST(current_timestamp() AS LONG) - CAST(notebook_start_time.start_time AS LONG) AS execution_seconds
FROM notebook_start_time;
