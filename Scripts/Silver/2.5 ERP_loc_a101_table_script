## Now we transforming thr Bronze table ERP_loc_A101 table to silver table 
%md
Start analyzing the erp loc a101 table
use catalog sql_datawarehouse;
%md
Let us pull the data from bronze table of erp_location of the customer
select * from sql_datawarehouse.bronze.erp_loc_a101;
%md
We can see that customer cid is related to cst_key from cust info table and we can get that location tagged
select * from sql_datawarehouse.silver.crm_cust_info;
%md
We can see the cid and cst_key has to be in same data format
%md
So we tranform the cid column in loc table
select cid from sql_datawarehouse.bronze.erp_loc_a101;

select cst_key from sql_datawarehouse.silver.crm_cust_info;
%md
Transformt the cid columns
select
replace(cid,'-','') as cid,
cntry
from sql_datawarehouse.bronze.erp_loc_a101;
%md
Let us see all the distinct locationss
select distinct cntry from sql_datawarehouse.bronze.erp_loc_a101;
%md
Now we need to standardize the country data
select
replace(cid,'-','') as cid,
case
  when trim(cntry)='DE' then 'Germany'
  when trim(cntry) in ('US','USA') then 'United States'
  when trim(cntry)='' or cntry is null then 'n/a'
  else cntry
end as cntry
from sql_datawarehouse.bronze.erp_loc_a101; 
%md
Let us see the tranformation worked or not?
select distinct
cntry as oldcountry,
case
  when trim(cntry)='DE' then 'Germany'
  when trim(cntry) in ('US','USA') then 'United States'
  when trim(cntry)='' or cntry is null then 'n/a'
  else cntry
end as cntry
from sql_datawarehouse.bronze.erp_loc_a101 order by cntry;
%md
We need to load the data as we didn't change any schema so no need to change the ddl
%md
### Before loading data into silver table we need to truncate the data to avoid duplicate data
truncate table sql_datawarehouse.silver.erp_loc_a101;
%md
we will load the data into silver table
insert into sql_datawarehouse.silver.erp_loc_a101(cid,cntry,dwh_create_date)
select
replace(cid,'-','') as cid,
case
  when trim(cntry)='DE' then 'Germany'
  when trim(cntry) in ('US','USA') then 'United States'
  when trim(cntry)='' or cntry is null then 'n/a'
  else cntry
end as cntry,
getdate() as dwh_create_date
from sql_datawarehouse.bronze.erp_loc_a101; 
%md
We loaded the data now need to check the quality in silver table
select distinct cntry from sql_datawarehouse.silver.erp_loc_a101;
select * from sql_datawarehouse.silver.erp_loc_a101;
%md
## NOW the data is standardized
